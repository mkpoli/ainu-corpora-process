# Copy to .env and adjust as needed. Loaded via python-dotenv.
#
# AINU_LARGE_DATA_DIR is the shared root for any multi-GB artifacts the
# pipelines produce or consume: Wiktionary dumps, decompressed XML, audio
# corpora, OCR scratch files, etc. Each pipeline creates its own
# subdirectory under this root (e.g. wiktionary-dumps/, audio/, ...),
# so keep this at a *parent* location rather than a pipeline-specific dir.
#
# Useful on WSL: point this at a Windows mount to avoid bloating the
# Linux VHD.
#
# Examples:
#   AINU_LARGE_DATA_DIR=/mnt/m/Workspace/Ainu
#   AINU_LARGE_DATA_DIR=/data/ainu
#
# If unset, scripts fall back to ./dictionary/output/_large inside the repo.
AINU_LARGE_DATA_DIR=
