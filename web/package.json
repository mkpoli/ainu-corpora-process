{
	"name": "web",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"scripts": {
		"sync:db": "node scripts/sync-database.mjs",
		"predev": "node scripts/sync-database.mjs",
		"dev": "vite dev",
		"prebuild": "node scripts/sync-database.mjs",
		"build": "vite build",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"publish:d1": "node scripts/publish-d1.mjs",
		"deploy": "bun run build && wrangler deploy"
	},
	"devDependencies": {
		"@inlang/paraglide-js": "^2.18.0",
		"@sveltejs/adapter-auto": "^7.0.1",
		"@sveltejs/adapter-cloudflare": "^7.2.8",
		"@sveltejs/kit": "^2.57.0",
		"@sveltejs/vite-plugin-svelte": "^7.0.0",
		"@tailwindcss/vite": "^4.3.0",
		"@types/node": "^25.8.0",
		"svelte": "^5.55.2",
		"svelte-check": "^4.4.6",
		"tailwindcss": "^4.3.0",
		"typescript": "^6.0.2",
		"vite": "^8.0.7",
		"wrangler": "^4.91.0"
	}
}
