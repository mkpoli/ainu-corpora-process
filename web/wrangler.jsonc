{
	"$schema": "node_modules/wrangler/config-schema.json",
	"name": "ainu-mdb",
	"main": ".svelte-kit/cloudflare/_worker.js",
	"compatibility_date": "2025-05-01",
	"compatibility_flags": ["nodejs_compat"],
	// Disable the *.workers.dev preview URL — the worker is reachable only
	// via the custom domain below.
	"workers_dev": false,
	"assets": {
		"binding": "ASSETS",
		"directory": ".svelte-kit/cloudflare"
	},
	// Cloudflare D1 binding for the morpheme database. The `database_name`
	// and `database_id` fields are rewritten by `bun run publish:d1`, which
	// mints a new datetime-suffixed database on each publish and imports the
	// SQL dump produced by `python -m morpheme_db.export_sqlite`.
	"d1_databases": [
		{
			"binding": "DB",
			"database_name": "ainu-mdb-20260530-1328",
			"database_id": "6f028b4c-5e97-4731-885d-9ecaa4e79b44"
		}
	],
	"routes": [
		{
			"pattern": "mdb.aynu.org",
			"custom_domain": true
		}
	],
	"observability": {
		"enabled": true
	}
}
